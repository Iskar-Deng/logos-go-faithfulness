{
  "name": "logos-go-faithfulness",
  "version": "0.1.0",
  "private": true,
  "description": "Tools for normalizing and inspecting LoGos Go explanations.",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "test": "node scripts/smoke-test.js",
    "download:rollout": "python3 scripts/download_rollout.py --output data/raw/logos_rollout_1k_all.json --sample-output data/raw/logos_rollout_1k_first3.json",
    "parse:rollout": "python3 scripts/parse_rollout_tree.py data/raw/logos_rollout_1k_all.json data/processed/logos_rollout_1k_all.tree.jsonl",
    "parse:rollout:first3": "python3 scripts/parse_rollout_tree.py data/raw/logos_rollout_1k_first3.json data/processed/logos_rollout_1k_first3.tree.jsonl",
    "build:viewer": "python3 scripts/build_viewer_data.py data/processed/logos_rollout_1k_all.tree.jsonl public/data/logos_rollout_1k_all.tree.json",
    "build:viewer:first3": "python3 scripts/build_viewer_data.py data/processed/logos_rollout_1k_first3.tree.jsonl public/data/logos_rollout_1k_first3.tree.json",
    "prepare:rollout": "npm run parse:rollout && npm run build:viewer",
    "prepare:rollout:first3": "npm run parse:rollout:first3 && npm run build:viewer:first3"
  },
  "dependencies": {
    "@sabaki/go-board": "^1.4.3",
    "express": "^4.18.2"
  }
}
